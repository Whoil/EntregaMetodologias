      Dog dog1 = new Dog();
      dog1.greeting();          // Woof!
      BigDog bigDog1 = new BigDog();
      bigDog1.greeting();       // Woow!

      // Using Polymorphism
      Animal animal1 = new Cat();
      animal1.greeting();       // Meow!
      Animal animal2 = new Dog();
      animal2.greeting();       // Woof!
      Animal animal3 = new BigDog();
      animal3.greeting();       // Woow!

      Animal animal4 = new Animal();  // Error (una clase abstracta no se puede instanciar)

      // Downcast
      Dog dog2 = (Dog)animal2;          // Correcto (animal2 es Dog)
      BigDog bigDog2 = (BigDog)animal3; // Correcto (animal3 es BigDog)
      Dog dog3 = (Dog)animal3;          // Correcto (BigDog es un Dog)
      Cat cat2 = (Cat)animal2;          // Error (animal2 es un Dog, no un Cat)

      dog2.greeting(dog3);      // Woooooooooof! (metodo de Dog, dog3 es bigdog y por tanto dog)
      dog3.greeting(dog2);      // Woooooooooof!
      dog2.greeting(bigDog2);   // Woooooooooof! (metodo de dog2, Dog)
      bigDog2.greeting(dog2);   // Woooooowwwww! (metodo de BigDog)
      bigDog2.greeting(bigDog1);// Woooooowwwww! (metodo de BigDog)
   }
}